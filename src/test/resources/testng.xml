<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Amazon.in Automation Suite" verbose="2" parallel="none">

    <parameter name="browser" value="chrome"/>

    <!-- ── HOMEPAGE TESTS ────────────────────────────────── -->
    <test name="Homepage Tests">
        <classes>
            <class name="com.amazon.tests.HomepageTest"/>
        </classes>
    </test>

    <!-- ── SEARCH TESTS ──────────────────────────────────── -->
    <test name="Search Tests">
        <classes>
            <class name="com.amazon.tests.SearchTest"/>
        </classes>
    </test>

    <!-- ── PRODUCT DETAIL TESTS ──────────────────────────── -->
    <test name="Product Detail Page Tests">
        <classes>
            <class name="com.amazon.tests.ProductDetailTest"/>
        </classes>
    </test>

    <!-- ── CART TESTS ────────────────────────────────────── -->
    <test name="Cart Tests">
        <classes>
            <class name="com.amazon.tests.CartTest"/>
        </classes>
    </test>

    <!-- ── FILTER & SORT TESTS ───────────────────────────── -->
    <test name="Filters and Sorting Tests">
        <classes>
            <class name="com.amazon.tests.FiltersTest"/>
        </classes>
    </test>

    <!-- ── SIGN-IN TESTS ─────────────────────────────────── -->
    <test name="Sign-In Tests">
        <classes>
            <class name="com.amazon.tests.SignInTest"/>
        </classes>
    </test>

</suite>
